{
  "$schema": "https://mintlify.com/docs.json",
  "name": "RareUI",
  "theme": "willow",
  "colors": {
    "primary": "#ffffff",
    "light": "#ffffff",
    "dark": "#0a0b1a"
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Codewithswappy/RareUI"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Codewithswappy/RareUI",
      "x": "https://x.com/heyyswap"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Installation",
            "pages": [
              "installation/install-nextjs",
              "installation/install-tailwind",
              "installation/add-utilities",
              "installation/cli"
            ]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Buttons",
            "pages": [
              "components/liquid-button",
              "components/glass-shimmer-button",
              "components/premium-button",
              "components/soft-button",
              "components/retro-pixel-button",
              "components/neumorphism3DButton"
            ]
          },
          {
            "group": "Cards & Overlays",
            "pages": [
              "components/particle-card",
              "components/premium-profile-card",
              "components/liquid-tooltip",
              "components/loading-spinner"
            ]
          },
          {
            "group": "Navigation",
            "pages": [
              "components/animated-tab",
              "components/floating-navigation",
              "components/toast-tabs"
            ]
          },
          {
            "group": "Text Animation",
            "pages": [
              "text-animation/magnetic-scatterText",
              "text-animation/sound-text",
              "text-animation/vapor-smokeText",
              "text-animation/word-magnet"
            ]
          },
          {
            "group": "Interactive Backgrounds",
            "pages": [
              "interactive-background/liquid-wave"
            ]
          },
          {
            "group": "3D Elements",
            "pages": [
              "3d-elements/book-3d",
              "3d-elements/liquid-metal"
            ]
          },
          {
            "group": "Sections",
            "pages": [
              "sections/image-expand-testimonial"
            ]
          }
        ]
      }
    ]
  }
}
